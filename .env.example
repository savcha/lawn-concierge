# ─── Google Cloud / Gemini ────────────────────────────────────────────────────
# Required: your GCP project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP region for Cloud Run deployment
GOOGLE_CLOUD_LOCATION=us-central1

# Use Vertex AI (with Application Default Credentials) instead of an AI Studio API key
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Alternative: use a Gemini API key (AI Studio) instead of ADC
# GEMINI_API_KEY=your-gemini-api-key

# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
# Free tier key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key

# ─── Google Calendar ──────────────────────────────────────────────────────────
# OAuth 2.0 credentials JSON file path (downloaded from GCP Console)
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json

# Path to store the OAuth token after first auth
GOOGLE_CALENDAR_TOKEN_FILE=token.json

# ─── Agent Configuration ─────────────────────────────────────────────────────
# Gemini model to use (gemini-2.0-flash is fast + cost-efficient)
AGENT_MODEL=gemini-2.0-flash

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
